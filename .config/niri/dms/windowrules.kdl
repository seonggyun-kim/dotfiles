// @id=wr_1771680036501994139 @name=FreeRDP
window-rule {
    match app-id="^com.freerdp.client"
    open-maximized-to-edges true
}

// @id=wr_1771706819522865157 @name=Thunderbird TbSync Window
window-rule {
    match app-id="^thunderbird-esr$" title="^TbSync account manager$"
    open-floating true
    min-height 800
}
