#!/usr/bin/env zsh
emulate -L zsh
setopt err_exit pipe_fail no_unset

real_fastfetch="${commands[fastfetch]:-}"
if [[ -z "${real_fastfetch}" ]]; then
  printf 'dotfiles-fastfetch: fastfetch is required\n' >&2
  exit 127
fi

refresh_cache=0
print_cache_path=0
tty_state=''
temp_dir=''

while [[ $# -gt 0 ]]; do
  case "$1" in
    --refresh-cache)
      refresh_cache=1
      ;;
    --cache-path)
      print_cache_path=1
      ;;
    *)
      break
      ;;
  esac
  shift
done

if [[ $# -gt 0 ]]; then
  exec "${real_fastfetch}" "$@"
fi

if [[ ! -t 1 && "${DOTFILES_FASTFETCH_FORCE:-0}" != "1" \
  && "${refresh_cache}" -ne 1 \
  && "${print_cache_path}" -ne 1 ]]; then
  exec "${real_fastfetch}"
fi

flush_tty_input() {
  perl -MPOSIX=tcflush,TCIFLUSH -e 'tcflush(0, TCIFLUSH)' 2>/dev/null || true
}

restore_tty() {
  if [[ -n "${tty_state}" ]]; then
    flush_tty_input
    stty "${tty_state}" 2>/dev/null || true
  fi
}

cleanup() {
  if [[ -n "${temp_dir}" ]]; then
    rm -rf "${temp_dir}"
  fi

  restore_tty
}

host_name="$(hostname -s 2>/dev/null || hostname 2>/dev/null || uname -n)"
host_name="${host_name%%.*}"
host_name="$(printf '%s' "${host_name:-host}" | tr '[:upper:]' '[:lower:]')"

figlet_font="big"
cache_version="v20"
cache_dir="${DOTFILES_FASTFETCH_CACHE_DIR:-${XDG_CACHE_HOME:-${HOME}/.cache}/dotfiles/fastfetch}"
cache_key="$(printf '%s-%s-%s' "${cache_version}" "${host_name}" "${figlet_font}" | tr -cs '[:alnum:]._-' '_')"
cache_file="${cache_dir}/${cache_key}.logo"

if [[ "${print_cache_path}" -eq 1 ]]; then
  printf '%s\n' "${cache_file}"
  exit 0
fi

trap cleanup EXIT INT TERM

if [[ -t 0 && -t 1 ]]; then
  tty_state="$(stty -g 2>/dev/null || true)"
  if [[ -n "${tty_state}" ]]; then
    stty -echo 2>/dev/null || true
  fi
fi

run_fastfetch() {
  local exit_status

  "${real_fastfetch}" --pipe false --logo-type file --logo "$1"
  exit_status=$?
  exit "${exit_status}"
}

if [[ "${refresh_cache}" -eq 0 && -s "${cache_file}" ]]; then
  run_fastfetch "${cache_file}"
fi

temp_dir="$(mktemp -d "${TMPDIR:-/tmp}/dotfiles-fastfetch.XXXXXX")"
logo_config="${temp_dir}/logo.jsonc"
logo_file="${temp_dir}/logo.txt"
banner_file="${temp_dir}/banner.txt"
composed_logo="${temp_dir}/composed.logo"

cat >"${logo_config}" <<'EOF'
{
  "modules": [
    {
      "type": "logo",
      "only": true
    }
  ]
}
EOF

if ! "${real_fastfetch}" --config "${logo_config}" --pipe false >"${logo_file}" 2>/dev/null; then
  "${real_fastfetch}"
  exit $?
fi

if [[ ! -s "${logo_file}" ]]; then
  "${real_fastfetch}"
  exit $?
fi

if (( $+commands[figlet] )); then
  if ! figlet -f "${figlet_font}" "${host_name}" >"${banner_file}" 2>/dev/null; then
    figlet "${host_name}" >"${banner_file}"
  fi
else
  printf '%s\n' "${host_name}" >"${banner_file}"
fi

if ! perl - "${logo_file}" "${banner_file}" "${composed_logo}" <<'PERL'
use strict;
use warnings;

my ($logo_path, $banner_path, $out_path) = @ARGV;

sub slurp {
  my ($path) = @_;
  open my $fh, '<', $path or die "open $path: $!";
  local $/;
  return <$fh>;
}

sub strip_controls {
  my ($text) = @_;
  $text =~ s/\e\][^\a]*(?:\a|\e\\)//gs;
  $text =~ s/\e\[[0-9;?]*[ -\/]*[@-~]//gs;
  $text =~ s/\x9b[0-9;?]*[ -\/]*[@-~]//gs;
  $text =~ s/\e[ -\/]*[@-~]//gs;
  $text =~ s/\r//g;
  return $text;
}

sub row_has_visible_text {
  my ($row) = @_;
  for my $cell (@{$row || []}) {
    return 1 if defined($cell) && $cell->[0] !~ /[ \t]/;
  }
  return 0;
}

sub last_visible_col {
  my ($row) = @_;
  for (my $col = $#{$row || []}; $col >= 0; $col--) {
    my $cell = $row->[$col];
    return $col if defined($cell) && $cell->[0] !~ /[ \t]/;
  }
  return -1;
}

sub line_visible_bounds {
  my ($line) = @_;
  my ($first, $last);

  for (my $col = 0; $col < length($line); $col++) {
    next if substr($line, $col, 1) =~ /[ \t]/;
    $first = $col if !defined $first;
    $last = $col;
  }

  return if !defined $first;
  return ($first, $last);
}

sub parse_sgr {
  my ($params, $fg_ref) = @_;
  my @params = length($params) ? split(/;/, $params) : (0);

  for (my $i = 0; $i < @params; $i++) {
    my $param = $params[$i] eq '' ? 0 : $params[$i];

    if ($param == 0 || $param == 39) {
      $$fg_ref = '';
    } elsif (($param >= 30 && $param <= 37) || ($param >= 90 && $param <= 97)) {
      $$fg_ref = "$param";
    } elsif ($param == 38 && ($params[$i + 1] // '') eq '5' && defined $params[$i + 2]) {
      $$fg_ref = join(';', @params[$i .. $i + 2]);
      $i += 2;
    } elsif ($param == 38 && ($params[$i + 1] // '') eq '2' && defined $params[$i + 4]) {
      $$fg_ref = join(';', @params[$i .. $i + 4]);
      $i += 4;
    }
  }
}

sub marker_for_color {
  my ($fg, $seen, $next_ref) = @_;
  return 0 if $fg eq '';

  if (!exists $seen->{$fg}) {
    $seen->{$fg} = $$next_ref <= 8 ? $$next_ref : 8;
    $$next_ref++ if $$next_ref < 8;
  }

  return $seen->{$fg};
}

sub parse_logo {
  my ($text) = @_;
  my @rows;
  my %seen_colors;
  my $next_marker = 1;
  my $fg = '';
  my ($row, $col) = (0, 0);

  while (length $text) {
    if ($text =~ s/^\e\][^\a]*(?:\a|\e\\)//s) {
      next;
    }

    if ($text =~ s/^\e\[([0-9;?]*)([ -\/]*)([@-~])//s) {
      parse_sgr($1, \$fg) if $3 eq 'm';
      next;
    }

    if ($text =~ s/^\x9b([0-9;?]*)([ -\/]*)([@-~])//s) {
      parse_sgr($1, \$fg) if $3 eq 'm';
      next;
    }

    if ($text =~ s/^\e[ -\/]*[@-~]//s) {
      next;
    }

    if ($text =~ s/^\r//s) {
      $col = 0;
      next;
    }

    if ($text =~ s/^\n//s) {
      $row++;
      $col = 0;
      next;
    }

    my $char = substr($text, 0, 1, '');
    $rows[$row][$col] = [$char, marker_for_color($fg, \%seen_colors, \$next_marker)];
    $col++;
  }

  shift @rows while @rows && !row_has_visible_text($rows[0]);
  pop @rows while @rows && !row_has_visible_text($rows[-1]);
  die "empty fastfetch logo\n" if !@rows;

  return @rows;
}

sub load_banner {
  my ($path) = @_;
  my @lines = split(/\n/, strip_controls(slurp($path)), -1);
  s/[ \t]+$// for @lines;

  shift @lines while @lines && $lines[0] !~ /[^ \t]/;
  pop @lines while @lines && $lines[-1] !~ /[^ \t]/;
  return ('') if !@lines;

  my ($global_first, $global_last);
  for my $line (@lines) {
    my ($first, $last) = line_visible_bounds($line);
    next if !defined $first;
    $global_first = $first if !defined($global_first) || $first < $global_first;
    $global_last = $last if !defined($global_last) || $last > $global_last;
  }

  return ('') if !defined $global_first;
  return map {
    my $line = substr($_, $global_first, $global_last - $global_first + 1);
    $line =~ s/[ \t]+$//;
    $line;
  } @lines;
}

sub grid_width {
  my (@rows) = @_;
  my $width = 0;

  for my $row (@rows) {
    my $last_col = last_visible_col($row);
    $width = $last_col + 1 if $last_col + 1 > $width;
  }

  return $width;
}

sub banner_width {
  my (@lines) = @_;
  my $width = 0;

  for my $line (@lines) {
    $width = length($line) if length($line) > $width;
  }

  return $width;
}

sub overlay_banner {
  my ($logo_ref, $banner_ref, $left, $top) = @_;

  for (my $row = 0; $row < @{$banner_ref}; $row++) {
    my $line = $banner_ref->[$row] // '';
    my ($first_col, $last_col) = line_visible_bounds($line);
    next if !defined $first_col;

    for (my $col = $first_col; $col <= $last_col; $col++) {
      my $char = $col < length($line) ? substr($line, $col, 1) : ' ';
      my $marker = $char =~ /[ \t]/ ? 0 : 9;
      $logo_ref->[$top + $row][$left + $col] = [$char, $marker];
    }
  }
}

sub write_logo {
  my ($path, $rows_ref, $height) = @_;
  open my $out, '>', $path or die "open $path: $!";

  my $current_marker = 0;
  for (my $row = 0; $row < $height; $row++) {
    my $cells = $rows_ref->[$row] || [];
    my $last_col = last_visible_col($cells);

    if ($last_col < 0) {
      print {$out} "\n";
      next;
    }

    for (my $col = 0; $col <= $last_col; $col++) {
      my ($char, $marker) = @{$cells->[$col] || [' ', 0]};

      if ($char !~ /[ \t]/ && $marker != $current_marker) {
        print {$out} '$' . $marker if $marker > 0;
        $current_marker = $marker;
      }

      print {$out} $char;
    }

    print {$out} "\n";
  }

  close $out;
}

my @logo = parse_logo(slurp($logo_path));
my @banner = load_banner($banner_path);

my $logo_width = grid_width(@logo);
my $logo_height = scalar @logo;
my $banner_width = banner_width(@banner);
my $banner_height = scalar @banner;

my $banner_left = int(($logo_width - $banner_width) / 2);
my $banner_top = int(($logo_height - $banner_height) / 2);
$banner_left = 0 if $banner_left < 0;
$banner_top = 0 if $banner_top < 0;

overlay_banner(\@logo, \@banner, $banner_left, $banner_top);

my $height = $logo_height;
$height = $banner_top + $banner_height if $banner_top + $banner_height > $height;
write_logo($out_path, \@logo, $height);
PERL
then
  "${real_fastfetch}"
  exit $?
fi

mkdir -p "${cache_dir}"
cache_tmp="$(mktemp "${cache_file}.XXXXXX")"
cp "${composed_logo}" "${cache_tmp}"
mv "${cache_tmp}" "${cache_file}"

if [[ "${refresh_cache}" -eq 1 ]]; then
  printf 'refreshed fastfetch logo cache: %s\n' "${cache_file}" >&2
fi

run_fastfetch "${cache_file}"
