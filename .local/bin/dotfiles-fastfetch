#!/usr/bin/env zsh
emulate -L zsh
setopt err_exit pipe_fail no_unset

real_fastfetch="${commands[fastfetch]:-}"

if [[ -z "${real_fastfetch}" ]]; then
  printf 'dotfiles-fastfetch: fastfetch is required\n' >&2
  exit 127
fi

refresh_cache=0
print_cache_path=0

case "${1:-}" in
  --refresh-cache|--refresh-logo-cache)
    refresh_cache=1
    shift
    ;;
  --cache-path)
    print_cache_path=1
    shift
    ;;
esac

if [[ $# -gt 0 ]]; then
  exec "${real_fastfetch}" "$@"
fi

if [[ ! -t 1 && "${DOTFILES_FASTFETCH_FORCE:-0}" != "1" && "${refresh_cache}" -ne 1 && "${print_cache_path}" -ne 1 ]]; then
  exec "${real_fastfetch}"
fi

host_name="$(hostname -s 2>/dev/null || hostname 2>/dev/null || uname -n)"
host_name="${host_name%%.*}"
host_name="$(printf '%s' "${host_name:-host}" | tr '[:upper:]' '[:lower:]')"
figlet_font="${DOTFILES_FASTFETCH_FIGLET_FONT:-big}"
cache_version="v6"

cache_dir="${DOTFILES_FASTFETCH_CACHE_DIR:-${XDG_CACHE_HOME:-${HOME}/.cache}/dotfiles/fastfetch}"
cache_key="$(printf '%s-%s-%s' "${cache_version}" "${host_name}" "${figlet_font}" | tr -cs '[:alnum:]._-' '_')"
cache_file="${cache_dir}/${cache_key}.logo"

if [[ "${print_cache_path}" -eq 1 ]]; then
  printf '%s\n' "${cache_file}"
  exit 0
fi

if [[ "${refresh_cache}" -ne 1 && -s "${cache_file}" ]]; then
  exec "${real_fastfetch}" --logo-type file-raw --logo "${cache_file}"
fi

temp_dir="$(mktemp -d "${TMPDIR:-/tmp}/dotfiles-fastfetch.XXXXXX")"
cleanup() {
  rm -rf "${temp_dir}"
}
trap cleanup EXIT

logo_config="${temp_dir}/logo.jsonc"
logo_file="${temp_dir}/logo.txt"
banner_file="${temp_dir}/banner.txt"
composed_logo="${temp_dir}/composed-logo.txt"

cat >"${logo_config}" <<'EOF'
{
  "modules": [
    {
      "type": "logo",
      "only": true
    }
  ]
}
EOF

if ! "${real_fastfetch}" --config "${logo_config}" --pipe false >"${logo_file}" 2>/dev/null; then
  "${real_fastfetch}"
  exit $?
fi

if [[ ! -s "${logo_file}" ]]; then
  "${real_fastfetch}"
  exit $?
fi

if (( $+commands[figlet] )); then
  if ! figlet -f "${figlet_font}" "${host_name}" >"${banner_file}" 2>/dev/null; then
    figlet "${host_name}" >"${banner_file}"
  fi
else
  printf '%s\n' "${host_name}" >"${banner_file}"
fi

strip_ansi() {
  sed -E $'s/\x1b\\[[0-9;?]*[ -/]*[@-~]//g'
}

visible_width() {
  local stripped
  stripped="$(printf '%s' "$1" | strip_ansi)"
  printf '%s\n' "${#stripped}"
}

visible_content_width() {
  local stripped
  stripped="$(printf '%s' "$1" | strip_ansi)"
  stripped="${stripped//[[:space:]]/}"
  printf '%s\n' "${#stripped}"
}

line_content_bounds() {
  local stripped="$1"
  local width="${#stripped}"
  local start=-1
  local end=-1
  local idx ch

  for ((idx = 1; idx <= width; idx++)); do
    ch="${stripped[$idx]}"
    if [[ "${ch}" != ' ' && "${ch}" != $'\t' ]]; then
      start=$((idx - 1))
      break
    fi
  done

  if (( start < 0 )); then
    printf -- '-1 -1\n'
    return 0
  fi

  for ((idx = width; idx >= 1; idx--)); do
    ch="${stripped[$idx]}"
    if [[ "${ch}" != ' ' && "${ch}" != $'\t' ]]; then
      end="${idx}"
      break
    fi
  done

  printf '%s %s\n' "${start}" "${end}"
}

repeat_spaces() {
  local count="$1"

  if (( count > 0 )); then
    printf '%*s' "${count}" ''
  fi
}

ansi_slice_line() {
  local line="$1"
  local start_col="$2"
  local end_col="$3"
  local idx=1
  local length="${#line}"
  local visible_col=0
  local output=''
  local active_sgr=''
  local ch seq

  while (( idx <= length )); do
    ch="${line[$idx]}"

    if [[ "${ch}" == $'\e' && "${line[$((idx + 1))]:-}" == '[' ]]; then
      seq=$'\e['
      idx=$((idx + 2))

      while (( idx <= length )); do
        ch="${line[$idx]}"
        seq+="${ch}"
        if [[ "${ch}" == [@-~] ]]; then
          break
        fi
        idx=$((idx + 1))
      done

      if [[ "${seq}" == *m ]]; then
        if [[ "${seq}" == $'\e[m' || "${seq}" == $'\e[0m' ]]; then
          active_sgr=''
        else
          active_sgr+="${seq}"
        fi
      fi

      if (( visible_col >= start_col && visible_col < end_col )); then
        output+="${seq}"
      fi
    else
      if (( visible_col >= start_col && visible_col < end_col )); then
        if [[ -z "${output}" && -n "${active_sgr}" ]]; then
          output+="${active_sgr}"
        fi
        output+="${ch}"
      fi
      visible_col=$((visible_col + 1))
    fi

    idx=$((idx + 1))
  done

  if [[ -n "${output}" ]]; then
    output+=$'\e[m'
  fi

  printf '%s' "${output}"
}

overlay_banner_row() {
  local logo_line="$1"
  local banner_row="$2"
  local banner_line="$3"
  local output left_width banner_col ch row_first row_last left_col right_col

  row_first="${banner_first_solid[$banner_row]:--1}"
  row_last="${banner_last_solid[$banner_row]:--1}"
  if (( row_first < 0 )); then
    printf '%s\n' "${logo_line}"
    return 0
  fi

  left_col=$((banner_start_col + row_first))
  right_col=$((banner_start_col + row_last + 1))

  output="$(ansi_slice_line "${logo_line}" 0 "${left_col}")"
  left_width="$(visible_width "${output}")"
  if (( left_width < left_col )); then
    output+="$(repeat_spaces "$((left_col - left_width))")"
  fi

  for ((banner_col = row_first; banner_col <= row_last; banner_col++)); do
    if (( banner_col < ${#banner_line} )); then
      ch="${banner_line[$((banner_col + 1))]}"
    else
      ch=' '
    fi

    output+="${ch}"
  done

  output+="$(ansi_slice_line "${logo_line}" "${right_col}" 2147483647)"
  printf '%s\n' "${output}"
}

typeset -a logo_lines
logo_lines=()
line=''
while IFS= read -r line || [[ -n "${line}" ]]; do
  logo_lines+=("${line}")
done <"${logo_file}"

last_logo_line="${#logo_lines[@]}"
while (( last_logo_line > 0 )); do
  if (( "$(visible_content_width "${logo_lines[$last_logo_line]}")" > 0 )); then
    break
  fi
  last_logo_line=$((last_logo_line - 1))
done

first_logo_line=1
while (( first_logo_line <= last_logo_line )); do
  if (( "$(visible_content_width "${logo_lines[$first_logo_line]}")" > 0 )); then
    break
  fi
  first_logo_line=$((first_logo_line + 1))
done

if (( last_logo_line == 0 )); then
  logo_lines=()
elif (( first_logo_line > 1 || last_logo_line < ${#logo_lines[@]} )); then
  logo_lines=("${logo_lines[@]:$((first_logo_line - 1)):$((last_logo_line - first_logo_line + 1))}")
fi

typeset -a banner_lines
banner_lines=()
line=''
while IFS= read -r line || [[ -n "${line}" ]]; do
  banner_lines+=("${line}")
done <"${banner_file}"

banner_min_col=-1
banner_max_col=-1
for line in "${banner_lines[@]}"; do
  read -r content_start content_end <<<"$(line_content_bounds "${line}")"
  if (( content_start >= 0 )); then
    if (( banner_min_col < 0 || content_start < banner_min_col )); then
      banner_min_col="${content_start}"
    fi
    if (( content_end > banner_max_col )); then
      banner_max_col="${content_end}"
    fi
  fi
done

if (( banner_min_col > 0 )); then
  for ((i = 1; i <= ${#banner_lines[@]}; i++)); do
    banner_lines[$i]="${banner_lines[$i]:${banner_min_col}:$((banner_max_col - banner_min_col))}"
  done
fi

last_banner_line="${#banner_lines[@]}"
while (( last_banner_line > 0 )); do
  if (( "$(visible_content_width "${banner_lines[$last_banner_line]}")" > 0 )); then
    break
  fi
  last_banner_line=$((last_banner_line - 1))
done

if (( last_banner_line < ${#banner_lines[@]} )); then
  banner_lines=("${banner_lines[@]:0:${last_banner_line}}")
fi

logo_width=0
typeset -a logo_centers
logo_centers=()
for line in "${logo_lines[@]}"; do
  line_width="$(visible_width "${line}")"
  if (( line_width > logo_width )); then
    logo_width="${line_width}"
  fi

  stripped_line="$(printf '%s' "${line}" | strip_ansi)"
  read -r content_start content_end <<<"$(line_content_bounds "${stripped_line}")"
  if (( content_start >= 0 )); then
    logo_centers+=("$((content_start + content_end))")
  fi
done

banner_width=0
for line in "${banner_lines[@]}"; do
  line_width="$(visible_width "${line}")"
  if (( line_width > banner_width )); then
    banner_width="${line_width}"
  fi
done

if (( banner_width > logo_width )); then
  logo_width="${banner_width}"
fi

typeset -a banner_first_solid banner_last_solid

logo_height="${#logo_lines[@]}"
banner_height="${#banner_lines[@]}"
canvas_height="${logo_height}"
if (( banner_height > canvas_height )); then
  canvas_height="${banner_height}"
fi

vertical_offset=$(( (canvas_height - banner_height) / 2 ))
if (( canvas_height % 2 == 1 && (canvas_height - banner_height) % 2 == 0 && vertical_offset > 0 )); then
  vertical_offset=$((vertical_offset - 1))
fi
banner_start_row=$(( vertical_offset + 1 ))
if (( banner_start_row < 1 )); then
  banner_start_row=1
fi

if (( ${#logo_centers[@]} > 0 )); then
  sorted_logo_centers=(${(on)logo_centers})
  logo_center="${sorted_logo_centers[$(((${#sorted_logo_centers[@]} + 1) / 2))]}"
  banner_start_col=$(( (logo_center - banner_width) / 2 ))
else
  banner_start_col=$(( (logo_width - banner_width) / 2 ))
fi
if (( banner_start_col < 0 )); then
  banner_start_col=0
fi

for ((row = 1; row <= banner_height; row++)); do
  line="${banner_lines[$row]:-}"
  banner_first_solid[$row]=-1
  banner_last_solid[$row]=-1

  for ((col = 0; col < banner_width; col++)); do
    if (( col < ${#line} )); then
      ch="${line[$((col + 1))]}"
    else
      ch=' '
    fi

    if [[ "${ch}" != ' ' && "${ch}" != $'\t' ]]; then
      if (( banner_first_solid[$row] < 0 )); then
        banner_first_solid[$row]="${col}"
      fi
      banner_last_solid[$row]="${col}"
    fi
  done
done

{
  for ((i = 1; i <= canvas_height; i++)); do
    banner_row=$((i - banner_start_row + 1))
    if (( banner_row >= 1 && banner_row <= banner_height )); then
      overlay_banner_row "${logo_lines[$i]:-}" "${banner_row}" "${banner_lines[$banner_row]:-}"
    else
      printf '%s\n' "${logo_lines[$i]:-}"
    fi
  done
} >"${composed_logo}"

mkdir -p "${cache_dir}"
cache_tmp="${cache_file}.${$}.tmp"
cp "${composed_logo}" "${cache_tmp}"
mv "${cache_tmp}" "${cache_file}"

if [[ "${refresh_cache}" -eq 1 ]]; then
  printf 'refreshed fastfetch logo cache: %s\n' "${cache_file}" >&2
fi

exec "${real_fastfetch}" --logo-type file-raw --logo "${cache_file}"
