include "%L"

# Shared compose sequences belong here and are tracked in git.
# Example:
<Multi_key> <e> <m> <a> <i> <l> : "seonggyun.kim@outlook.com"

# Greek letters
<Multi_key> <a> <l> <p> <h> <a> : "α"
<Multi_key> <A> <l> <p> <h> <a> : "Α"
<Multi_key> <b> <e> <t> <a> : "β"
<Multi_key> <B> <e> <t> <a> : "Β"
<Multi_key> <g> <a> <m> <m> <a> : "γ"
<Multi_key> <G> <a> <m> <m> <a> : "Γ"
<Multi_key> <d> <e> <l> <t> <a> : "δ"
<Multi_key> <D> <e> <l> <t> <a> : "Δ"
<Multi_key> <e> <p> <s> <i> <l> <o> <n> : "ε"
<Multi_key> <E> <p> <s> <i> <l> <o> <n> : "Ε"
<Multi_key> <z> <e> <t> <a> : "ζ"
<Multi_key> <Z> <e> <t> <a> : "Ζ"
<Multi_key> <e> <t> <a> : "η"
<Multi_key> <E> <t> <a> : "Η"
<Multi_key> <t> <h> <e> <t> <a> : "θ"
<Multi_key> <T> <h> <e> <t> <a> : "Θ"
<Multi_key> <i> <o> <t> <a> : "ι"
<Multi_key> <I> <o> <t> <a> : "Ι"
<Multi_key> <k> <a> <p> <p> <a> : "κ"
<Multi_key> <K> <a> <p> <p> <a> : "Κ"
<Multi_key> <l> <a> <m> <b> <d> <a> : "λ"
<Multi_key> <L> <a> <m> <b> <d> <a> : "Λ"
<Multi_key> <m> <u> : "μ"
<Multi_key> <M> <u> : "Μ"
<Multi_key> <n> <u> : "ν"
<Multi_key> <N> <u> : "Ν"
<Multi_key> <x> <i> : "ξ"
<Multi_key> <X> <i> : "Ξ"
<Multi_key> <o> <m> <i> <c> <r> <o> <n> : "ο"
<Multi_key> <O> <m> <i> <c> <r> <o> <n> : "Ο"
<Multi_key> <p> <i> : "π"
<Multi_key> <P> <i> : "Π"
<Multi_key> <r> <h> <o> : "ρ"
<Multi_key> <R> <h> <o> : "Ρ"
<Multi_key> <s> <i> <g> <m> <a> : "σ"
<Multi_key> <S> <i> <g> <m> <a> : "Σ"
<Multi_key> <t> <a> <u> : "τ"
<Multi_key> <T> <a> <u> : "Τ"
<Multi_key> <u> <p> <s> <i> <l> <o> <n> : "υ"
<Multi_key> <U> <p> <s> <i> <l> <o> <n> : "Υ"
<Multi_key> <p> <h> <i> : "φ"
<Multi_key> <P> <h> <i> : "Φ"
<Multi_key> <c> <h> <i> : "χ"
<Multi_key> <C> <h> <i> : "Χ"
<Multi_key> <p> <s> <i> : "ψ"
<Multi_key> <P> <s> <i> : "Ψ"
<Multi_key> <o> <m> <e> <g> <a> : "ω"
<Multi_key> <O> <m> <e> <g> <a> : "Ω"

include "%H/.XCompose.local"

# ~/.XCompose.local is optional and intended for local/private overrides.
